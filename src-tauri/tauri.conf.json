{
  "productName": "Spell Book",
  "version": "1.0.0",
  "identifier": "com.spellbook.library",
  "build": {
    "frontendDist": "../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Spell Book",
        "width": 1280,
        "height": 860,
        "resizable": true,
        "center": true,
        "backgroundColor": "#0d1117"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
